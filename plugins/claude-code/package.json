{
  "name": "condense-claude-code",
  "version": "0.3.2",
  "description": "Recoverable, model-ranked context condensation for Claude Code.",
  "type": "module",
  "author": "Aryan Shrivastava",
  "license": "BSD-3-Clause",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "check": "biome check .",
    "format": "biome format --write src test",
    "test": "bun test",
    "test:bootstrap": "bun run ./test/bootstrap-smoke.ts",
    "test:integration": "bun test ./test/integration.ts",
    "test:smoke": "bun run ./test/resume-smoke.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.205",
    "@modelcontextprotocol/sdk": "1.29.0",
    "re2js": "2.8.6"
  },
  "files": [
    ".claude-plugin",
    ".mcp.json",
    "bun.lock",
    "LICENSE.md",
    "NOTICE.md",
    "skills",
    "src"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/bun": "1.3.14",
    "@types/node": "22.10.2",
    "typescript": "5.7.3"
  }
}
