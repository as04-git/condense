{
  "name": "condense",
  "version": "0.3.2",
  "description": "Lossless, recoverable context condensation for coding agents.",
  "private": true,
  "type": "module",
  "author": "Aryan Shrivastava",
  "license": "BSD-3-Clause",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "check": "biome check plugins/claude-code",
    "format": "biome format --write plugins/claude-code/src plugins/claude-code/test",
    "test": "bun test plugins/claude-code/test",
    "test:bootstrap": "bun run plugins/claude-code/test/bootstrap-smoke.ts",
    "test:integration": "bun test ./plugins/claude-code/test/integration.ts",
    "test:smoke": "bun run plugins/claude-code/test/resume-smoke.ts",
    "typecheck": "tsc -p plugins/claude-code/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.207",
    "@modelcontextprotocol/sdk": "1.29.0",
    "re2js": "2.8.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/bun": "1.3.14",
    "@types/node": "26.1.1",
    "typescript": "7.0.2"
  }
}
